# ============================================================================
# OpenHands — Variables de entorno (copia a .env o .env.enc)
# ============================================================================
# Copia este archivo y completa los valores:
#
#   cp scripts/.env.template .env
#   ${EDITOR:-vi} .env
#
# Para cifrar con age + sops (recomendado en producción):
#   just encrypt
#
# Nota: LLM_MODEL y LLM_BASE_URL también se pueden configurar desde la UI
# de OpenHands (Settings). Si están definidas aquí, tienen precedencia.
# ============================================================================

# ── API Key del LLM (OBLIGATORIA) ──────────────────────────────────────────
LLM_API_KEY="sk-..."

# ── Modelo LLM (OPCIONAL — si no se define, se configura desde la UI) ──────
# Ejemplos:
#   DeepSeek v3:  LLM_MODEL="deepseek/deepseek-chat"
#   GPT-4o:       LLM_MODEL="gpt-4o"
#   Claude:       LLM_MODEL="anthropic/claude-3-5-sonnet-20241022"
#   Ollama local: LLM_MODEL="ollama/llama3.2"
# LLM_MODEL="deepseek/deepseek-chat"

# ── URL base del LLM (OPCIONAL) ────────────────────────────────────────────
# Necesario para endpoints no-OpenAI (Ollama, DeepSeek, Azure, proxies…):
# LLM_BASE_URL="https://api.deepseek.com"
# LLM_BASE_URL="http://localhost:11434"

# ── Parámetros del LLM (OPCIONAL) ──────────────────────────────────────────
# LLM_TEMPERATURE="0.4"
# LLM_MAX_OUTPUT_TOKENS="4096"

# ── Timeout del sandbox en segundos (OPCIONAL, default: 300) ───────────────
# SANDBOX_TIMEOUT="300"

# ── Puerto de la UI (OPCIONAL, default: 3000) ──────────────────────────────
# OPENHANDS_PORT="3000"

# ── Imagen Docker (OPCIONAL) ───────────────────────────────────────────────
# OPENHANDS_IMAGE="docker.openhands.dev/openhands/openhands:1.6"

# ── Imagen del agent-server (OPCIONAL) ─────────────────────────────────────
# AGENT_SERVER_IMAGE_REPOSITORY="ghcr.io/openhands/agent-server"
# AGENT_SERVER_IMAGE_TAG="1.15.0-python"

# ── Puerto TCP para Podman rootless (OPCIONAL, default: 12375) ─────────────
# Solo se usa cuando se detecta Podman en modo rootless (default macOS).
# Cambia si el puerto 12375 ya está en uso.
# PODMAN_API_PORT="12375"
