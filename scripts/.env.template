# ============================================================================
# OpenHands — Variables de entorno (copia a .env o .env.enc)
# ============================================================================
# Copia este archivo y completa los valores:
#
#   cp scripts/.env.template .env
#   ${EDITOR:-vi} .env
#
# Para cifrar con age + sops (recomendado en producción):
#   just encrypt
# ============================================================================

# ── API Key del LLM (OBLIGATORIA) ──────────────────────────────────────────
# Tu API key del LLM configurado en config/config.toml
LLM_API_KEY="sk-..."

# ── URL base del LLM (OPCIONAL) ────────────────────────────────────────────
# Para usar Ollama, proxies, o endpoints compatibles con OpenAI:
# LLM_BASE_URL="http://localhost:11434/v1"

# ── Directorio de trabajo (OPCIONAL) ───────────────────────────────────────
# Ruta absoluta al directorio que OpenHands puede modificar.
# Por defecto: <proyecto>/workspace
# WORKSPACE_DIR="/ruta/absoluta/al/workspace"

# ── Puerto de la UI (OPCIONAL) ─────────────────────────────────────────────
# OPENHANDS_PORT="3000"

# ── Imagen Docker (OPCIONAL) ───────────────────────────────────────────────
# OPENHANDS_IMAGE="docker.openhands.dev/openhands/openhands:1.6"
