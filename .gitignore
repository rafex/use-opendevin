# ============================================================================
# .gitignore — OpenDeven Script
# ============================================================================

# ── Secretos ───────────────────────────────────────────────────────────────
.env                          # Variables de entorno sin cifrar
.env.*.enc                    # Cifrados con sops (se generan localmente)

# ── Directorio de trabajo de OpenDevin ─────────────────────────────────────
workspace/                    # Directorio que OpenDevin modifica

# ── Sistema ────────────────────────────────────────────────────────────────
.DS_Store
*.swp
*.swo
*~

# ── Docker ─────────────────────────────────────────────────────────────────
.docker/

# opencode — worktrees (generados, no committear)
.opencode/worktrees/
.opencode/worktrees.db
.opencode/worktrees.log

# opencode (local, no versionar)
.opencode/sessions.db
.opencode/sessions.db-shm
.opencode/sessions.db-wal
.opencode/node_modules/
session-ses_*.md
